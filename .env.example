# Project
APP_NAME="AI Quant Watch"
APP_ENV=development
ENVIRONMENT=development

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000
FRONTEND_HOST_PORT=3000
BACKEND_HOST_PORT=8000
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379

# Backend
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
TRUSTED_HOSTS=localhost,127.0.0.1
SESSION_COOKIE_NAME=ai_quant_session
SESSION_COOKIE_SECURE=false
SESSION_EXPIRE_HOURS=168
RUN_SCHEDULER_IN_API=true
ENABLE_ADMIN_MONITORING_ACTIONS=true
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
LOGIN_RATE_LIMIT_MAX_FAILURES=8
MARKET_TIMEZONE=Asia/Shanghai
MARKET_DATA_PROVIDER=akshare
MARKET_CACHE_TTL_SECONDS=30
SIGNAL_COOLDOWN_SECONDS=1800
MARKET_REFRESH_INTERVAL_SECONDS=60
STRATEGY_SCAN_INTERVAL_SECONDS=60

# Database
POSTGRES_DB=ai_quant
POSTGRES_USER=ai_quant
POSTGRES_PASSWORD=ai_quant_dev_password
DATABASE_URL=postgresql+psycopg://ai_quant:ai_quant_dev_password@postgres:5432/ai_quant

# Redis
REDIS_URL=redis://redis:6379/0

# AI provider. Leave AI_PROVIDER=mock when no model endpoint is configured.
AI_PROVIDER=mock
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
AI_TIMEOUT_SECONDS=30
AI_MAX_OUTPUT_TOKENS=1200
AI_RATE_LIMIT_WINDOW_SECONDS=30
AI_RATE_LIMIT_MAX_REQUESTS=5
