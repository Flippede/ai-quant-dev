# Copy to .env.production and replace all example values before deployment.

APP_NAME="AI Quant Watch"
APP_ENV=production
ENVIRONMENT=production

# Public URLs. For same-domain Nginx proxying, keep frontend API base empty so the browser calls /api.
PUBLIC_BASE_URL=https://quant.example.com
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_WS_BASE_URL=wss://quant.example.com
FRONTEND_BIND_HOST=127.0.0.1
FRONTEND_HOST_PORT=13000
BACKEND_BIND_HOST=127.0.0.1
BACKEND_HOST_PORT=18000

# Security
BACKEND_CORS_ORIGINS=https://quant.example.com
TRUSTED_HOSTS=quant.example.com,localhost,127.0.0.1
SESSION_COOKIE_NAME=ai_quant_session
SESSION_COOKIE_SECURE=true
SESSION_EXPIRE_HOURS=168
RUN_SCHEDULER_IN_API=false
ENABLE_ADMIN_MONITORING_ACTIONS=false
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
LOGIN_RATE_LIMIT_MAX_FAILURES=8

# Market data and monitoring
MARKET_TIMEZONE=Asia/Shanghai
MARKET_DATA_PROVIDER=akshare
MARKET_CACHE_TTL_SECONDS=30
SIGNAL_COOLDOWN_SECONDS=1800
MARKET_REFRESH_INTERVAL_SECONDS=60
STRATEGY_SCAN_INTERVAL_SECONDS=60

# Database. PostgreSQL and Redis are internal-only in docker-compose.prod.yml.
POSTGRES_DB=ai_quant
POSTGRES_USER=ai_quant
POSTGRES_PASSWORD=replace-with-strong-password
DATABASE_URL=postgresql+psycopg://ai_quant:replace-with-strong-password@postgres:5432/ai_quant

# Redis
REDIS_URL=redis://redis:6379/0

# AI provider. Use mock only for pre-production dry runs.
AI_PROVIDER=openai_compatible
AI_BASE_URL=https://your-openai-compatible-provider.example/v1
AI_API_KEY=replace-with-provider-key
AI_MODEL=replace-with-model
AI_TIMEOUT_SECONDS=30
AI_MAX_OUTPUT_TOKENS=1200
AI_RATE_LIMIT_WINDOW_SECONDS=30
AI_RATE_LIMIT_MAX_REQUESTS=5
